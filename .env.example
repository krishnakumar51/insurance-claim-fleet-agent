# Copy this file to `.env` and fill in real values for local/dev use.
# `.env` is gitignored -- never commit real API keys.
# None of these are required for the graded path (`docker compose up` /
# `make demo`), which defaults to REPLAY_LLM=true and needs no key at all.

# --- Kit's official contract (TASK.md Step 7 / README_KIT.md) ---------------
# REPLAY_LLM=true (default): replay committed transcripts, fully offline, no key needed.
# REPLAY_LLM=false: make real calls using LLM_API_KEY / LLM_MODEL / LLM_BASE_URL below.
REPLAY_LLM=true

# Dataset directory (default: seed). Graders swap this for the held-out seed.
SEED_DIR=seed

# Your live-assigned CASE_ID -- drives the amendment (role + threshold), must
# appear in SCOPE.md, the audit bundle, and your final commit message.
CASE_ID=CEDX-EB3505

# Intake "now" used for STALE detection.
PIPELINE_NOW=2026-06-26

# Official real-LLM path (used when REPLAY_LLM=false). Must support >=1 of
# gpt-4o-mini / claude-3-5-haiku / gemini-1.5-flash.
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini
#   LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# --- Our dev-only extension: OpenRouter -------------------------------------
# We don't hold a direct OpenAI/Anthropic/Gemini key, so local/dev real-LLM
# runs go through OpenRouter (an OpenAI-compatible gateway that proxies to the
# genuine upstream providers). These only take effect when LLM_API_KEY/
# LLM_MODEL above are NOT set -- see app/config.py for the precedence order.
OPENROUTER_API_KEY=
LLM_MODEL_CHEAP=openai/gpt-4o-mini
LLM_MODEL_STRONG=anthropic/claude-3.5-haiku

# --- Budget ceilings (Step 5 / BUDGET_EXCEEDED) -----------------------------
MAX_COST_USD_PER_RECORD=0.02
MAX_STEPS_PER_RECORD=6
